<!-- ── PRACTICE AREAS ── -->
<section class="practice" id="areas">
  <div class="practice-header">
    <div>
      <p class="section-label">Especialización</p>
      <h2 class="section-title">Áreas de<br><em>Práctica</em></h2>
    </div>
    <a href="/es/contacto/" class="btn-ghost">Solicitar consulta</a>
  </div>
  <div class="practice-grid">
    <div class="area-card" data-reveal>
      <p class="area-num">01</p>
      <h3 class="area-title">Asesoría en Inversiones</h3>
      <p class="area-desc">Análisis de tratados bilaterales, normativa latinoamericana y desarrollo de proyectos internacionales con foco en Latinoamérica.</p>
    </div>
    <div class="area-card" data-reveal data-reveal-delay="1">
      <p class="area-num">02</p>
      <h3 class="area-title">Litigios y Métodos Alternativos de Resolución de Conflictos</h3>
      <p class="area-desc">Prevención y resolución de conflictos. Patrocinio y representación en procesos judiciales y arbitrajes internacionales.</p>
    </div>
    <div class="area-card" data-reveal data-reveal-delay="2">
      <p class="area-num">03</p>
      <h3 class="area-title">Corporativo – M&amp;A</h3>
      <p class="area-desc">Estructuras corporativas simples y complejas, fusiones, adquisiciones, escisiones y disoluciones de empresas.</p>
    </div>
    <div class="area-card" data-reveal data-reveal-delay="3">
      <p class="area-num">04</p>
      <h3 class="area-title">Telecomunicaciones</h3>
      <p class="area-desc">Acompañamiento en títulos habilitantes, representación ante entes reguladores y revisión de contratos de adhesión.</p>
    </div>
    <div class="area-card" data-reveal data-reveal-delay="4">
      <p class="area-num">05</p>
      <h3 class="area-title">Energético</h3>
      <p class="area-desc">Permisos petroleros y mineros, negociación de contratos, JVAs, análisis ambiental y social en el sector energético.</p>
    </div>
    <div class="area-card" data-reveal data-reveal-delay="4">
      <p class="area-num">06</p>
      <h3 class="area-title">Due Diligence</h3>
      <p class="area-desc">Investigación del sector, emisión de informes en español, inglés y francés para sectores extractivos e infraestructura.</p>
    </div>
  </div>
</section>

<!-- ── BLOG ── -->
<section class="blog" id="blog">
  <p class="section-label">Publicaciones</p>
  <h2 class="section-title">Nuestro <em>Blog</em></h2>

  {% set posts = collections.postsES %}
  {% if posts and posts.length > 0 %}
    <div class="blog-grid">
      <!-- Featured post -->
      <div class="blog-featured">
        {% if posts[0].data.image %}
          <img src="{{ posts[0].data.image }}" alt="{{ posts[0].data.image_alt or posts[0].data.title }}" loading="lazy">
        {% else %}
          <div style="width:100%;height:100%;background:var(--cream-dark);"></div>
        {% endif %}
        <div class="blog-featured-overlay">
          <p class="blog-date">{{ posts[0].date | readableDate }}</p>
          <a href="{{ posts[0].url }}" class="blog-title-link">{{ posts[0].data.title }}</a>
          {% if posts[0].data.excerpt %}
            <p class="blog-excerpt">{{ posts[0].data.excerpt }}</p>
          {% endif %}
        </div>
      </div>

      <!-- Side posts -->
      <div class="blog-side">
        {% if posts[1] %}
          <div class="blog-mini">
            <p class="blog-date">{{ posts[1].date | readableDate }}</p>
            <a href="{{ posts[1].url }}" class="blog-mini-title">{{ posts[1].data.title }}</a>
            <a href="{{ posts[1].url }}" class="pillar-link">Leer más &rarr;</a>
          </div>
        {% endif %}
        {% if posts[2] %}
          <div class="blog-mini">
            <p class="blog-date">{{ posts[2].date | readableDate }}</p>
            <a href="{{ posts[2].url }}" class="blog-mini-title">{{ posts[2].data.title }}</a>
            <a href="{{ posts[2].url }}" class="pillar-link">Leer más &rarr;</a>
          </div>
        {% endif %}
        <div class="blog-mini" style="flex:1; display:flex; flex-direction:column; justify-content:center; align-items:center; gap:1rem; padding:3rem 2rem; background:rgba(184,150,90,0.08); border-left:2px solid var(--gold);">
          <p style="font-family:var(--serif); font-size:1.05rem; font-style:italic; color:var(--cream-light); text-align:center; line-height:1.5;">Mantente informado sobre el desarrollo legal en la región</p>
          <a href="/es/contacto/" class="btn-primary" style="background:var(--gold-dark);">Suscribirse</a>
        </div>
      </div>
    </div>
  {% else %}
    <div style="color:rgba(237,233,224,0.4); font-size:0.85rem; padding:3rem 0;">
      Próximamente nuevas publicaciones.
    </div>
  {% endif %}
</section>

<!-- ── CONTACT ── -->
<section class="contact" id="contacto">
  <div class="contact-info">
    <p class="section-label">Escríbenos</p>
    <h2 class="section-title">Solicita una<br><em>consulta gratuita</em></h2>
    <p>Nuestro equipo está disponible para atender tus necesidades legales en Ecuador, Colombia, España y Latinoamérica. Ofrecemos una consulta inicial para explorar cómo Tesserae puede acompañarte.</p>
    <div class="contact-details">
      <div class="contact-detail">
        <strong>Email</strong>
        <span>info@tesseraebureau.com</span>
      </div>
      <div class="contact-detail">
        <strong>Ecuador</strong>
        <span>Av. Eloy Alfaro y Av. 6 de Diciembre, Ed. ZIZA, Piso 3, Of. 303 – Quito &middot; (593) 2 392 3057</span>
      </div>
      <div class="contact-detail">
        <strong>Colombia</strong>
        <span>Calle 145 No. 46-80, Bogotá D.C. &middot; (57) 301 542 9181</span>
      </div>
      <div class="contact-detail">
        <strong>Idiomas</strong>
        <span>Español, Inglés y Francés</span>
      </div>
    </div>
  </div>
  <form class="contact-form" name="contacto-es" method="POST" data-netlify="true" netlify-honeypot="bot-field">
    <input type="hidden" name="form-name" value="contacto-es">
    <p style="display:none"><label>No llenar: <input name="bot-field"></label></p>
    <div class="form-row">
      <div class="form-group">
        <label for="nombre">Nombre</label>
        <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required>
      </div>
      <div class="form-group">
        <label for="apellido">Apellido</label>
        <input type="text" id="apellido" name="apellido" placeholder="Tu apellido" required>
      </div>
    </div>
    <div class="form-group">
      <label for="email">Correo Electrónico</label>
      <input type="email" id="email" name="email" placeholder="tu@empresa.com" required>
    </div>
    <div class="form-group">
      <label for="area">Área de Interés</label>
      <select id="area" name="area">
        <option value="">Selecciona un área</option>
        <option>Asesoría en Inversiones</option>
        <option>Litigios y Arbitraje</option>
        <option>Corporativo · M&amp;A</option>
        <option>Telecomunicaciones</option>
        <option>Energético · Minería · Petróleo</option>
        <option>Infraestructura y Construcción</option>
        <option>Due Diligence</option>
      </select>
    </div>
    <div class="form-group">
      <label for="mensaje">Mensaje</label>
      <textarea id="mensaje" name="mensaje" placeholder="Describe brevemente tu necesidad legal…"></textarea>
    </div>
    <button type="submit" class="btn-submit">Enviar Mensaje</button>
  </form>
</section>
