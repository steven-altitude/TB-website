    <div class="area-card" data-reveal data-reveal-delay="1">
      <p class="area-num">02</p>
      <h3 class="area-title">Litigation &amp; Alternative Dispute Resolution</h3>
      <p class="area-desc">Prevention and resolution of conflicts. Sponsorship and representation in judicial proceedings and international commercial arbitrations.</p>
    </div>
    <div class="area-card" data-reveal data-reveal-delay="2">
      <p class="area-num">03</p>
      <h3 class="area-title">Corporate – M&amp;A</h3>
      <p class="area-desc">Corporate governance, mergers, acquisitions, spin-offs and transactional structuring across jurisdictions.</p>
    </div>
    <div class="area-card" data-reveal data-reveal-delay="3">
      <p class="area-num">04</p>
      <h3 class="area-title">Telecommunications</h3>
      <p class="area-desc">Legal and regulatory advisory in data protection, technology contracts, and telecom matters before regulatory bodies.</p>
    </div>
    <div class="area-card" data-reveal data-reveal-delay="4">
      <p class="area-num">05</p>
      <h3 class="area-title">Energy (Mining, Gas, Energy &amp; Oil)</h3>
      <p class="area-desc">Mining, petroleum, gas, and renewable energy regulation — litigation, licensing, and compliance across the energy lifecycle.</p>
    </div>
    <div class="area-card" data-reveal data-reveal-delay="5">
      <p class="area-num">06</p>
      <h3 class="area-title">Infrastructure &amp; Construction</h3>
      <p class="area-desc">Legal advisory for strategic infrastructure projects, public works and public-private partnerships — from bidding documents to project closure.</p>
    </div>
    <div class="area-card area-card--wide" data-reveal>
      <p class="area-num">07</p>
      <h3 class="area-title">Due Diligence</h3>
      <p class="area-desc">Rigorous legal diagnostics for informed investment decisions. Reports in Spanish and English for extractive, telecommunications, infrastructure and corporate sectors.</p>
    </div>
  </div>
</section>

<!-- ── BLOG ── -->
<section class="blog" id="blog">
  <p class="section-label">Publications</p>
  <h2 class="section-title">Our <em>Blog</em></h2>

  {% set posts = collections.postsEN %}
  {% if posts and posts.length > 0 %}
    <div class="blog-grid">
      <div class="blog-featured">
        {% if posts[0].data.image %}
          <img src="{{ posts[0].data.image }}" alt="{{ posts[0].data.image_alt or posts[0].data.title }}" loading="lazy">
        {% else %}
          <div style="width:100%;height:100%;background:var(--cream-dark);"></div>
        {% endif %}
        <div class="blog-featured-overlay">
          <p class="blog-date">{{ posts[0].date | readableDate("en-US") }}</p>
          <a href="{{ posts[0].url }}" class="blog-title-link">{{ posts[0].data.title }}</a>
          {% if posts[0].data.excerpt %}
            <p class="blog-excerpt">{{ posts[0].data.excerpt }}</p>
          {% endif %}
        </div>
      </div>
      <div class="blog-side">
        {% if posts[1] %}
          <div class="blog-mini">
            <p class="blog-date">{{ posts[1].date | readableDate("en-US") }}</p>
            <a href="{{ posts[1].url }}" class="blog-mini-title">{{ posts[1].data.title }}</a>
            <a href="{{ posts[1].url }}" class="pillar-link">Read more &rarr;</a>
          </div>
        {% endif %}
        {% if posts[2] %}
          <div class="blog-mini">
            <p class="blog-date">{{ posts[2].date | readableDate("en-US") }}</p>
            <a href="{{ posts[2].url }}" class="blog-mini-title">{{ posts[2].data.title }}</a>
            <a href="{{ posts[2].url }}" class="pillar-link">Read more &rarr;</a>
          </div>
        {% endif %}
        <div class="blog-mini" style="flex:1; display:flex; flex-direction:column; justify-content:center; align-items:center; gap:1rem; padding:3rem 2rem; background:rgba(184,150,90,0.08); border-left:2px solid var(--gold);">
          <p style="font-family:var(--serif); font-size:1.05rem; font-style:italic; color:var(--cream-light); text-align:center; line-height:1.5;">Stay informed on legal developments across the region</p>
          <a href="/en/contact/" class="btn-primary" style="background:var(--gold-dark);">Subscribe</a>
        </div>
      </div>
    </div>
  {% else %}
    <div style="color:rgba(237,233,224,0.4); font-size:0.85rem; padding:3rem 0;">No posts published yet.</div>
  {% endif %}
</section>

<!-- ── CONTACT ── -->
<section class="contact" id="contact">
  <div class="contact-info">
    <p class="section-label">Get in Touch</p>
    <h2 class="section-title">Request a free<br><em>consultation</em></h2>
    <p style="text-align:justify;">Our team is available to address your legal needs in Ecuador, Colombia, Spain and Latin America. We offer an initial consultation to explore how Tesserae can accompany you.</p>
    <div class="contact-details">
      <div class="contact-detail">
        <strong>Email</strong>
        <span>info@tesseraebureau.com</span>
      </div>
      <div class="contact-detail">
        <strong>Ecuador</strong>
        <span>Av. Eloy Alfaro &amp; Av. 6 de Diciembre, Ed. ZIZA, Floor 3, Office 303 – Quito &middot; +593 2 392 3057</span>
      </div>
      <div class="contact-detail">
        <strong>Colombia</strong>
        <span>Calle 145 No. 46-80, Bogot&aacute; D.C. &middot; +57 301 542 9181</span>
      </div>
      <div class="contact-detail">
        <strong>Languages</strong>
        <span>Spanish and English</span>
      </div>
    </div>
  </div>
  <form class="contact-form" name="contact-en" method="POST" data-netlify="true" netlify-honeypot="bot-field">
    <input type="hidden" name="form-name" value="contact-en">
    <p style="display:none"><label>Do not fill: <input name="bot-field"></label></p>
    <div class="form-row">
      <div class="form-group">
        <label for="first-name">First Name</label>
        <input type="text" id="first-name" name="first_name" placeholder="Your first name" required>
      </div>
      <div class="form-group">
        <label for="last-name">Last Name</label>
        <input type="text" id="last-name" name="last_name" placeholder="Your last name" required>
      </div>
    </div>
    <div class="form-group">
      <label for="email-en">Email Address</label>
      <input type="email" id="email-en" name="email" placeholder="you@company.com" required>
    </div>
    <div class="form-group">
      <label for="area-en">Area of Interest</label>
      <select id="area-en" name="area">
        <option value="">Select an area</option>
        <option>Investment Consulting</option>
        <option>Litigation &amp; ADR</option>
        <option>Corporate · M&amp;A</option>
        <option>Telecommunications</option>
        <option>Energy · Mining · Oil</option>
        <option>Infrastructure &amp; Construction</option>
        <option>Due Diligence</option>
      </select>
    </div>
    <div class="form-group">
      <label for="message-en">Message</label>
      <textarea id="message-en" name="message" placeholder="Briefly describe your legal need…"></textarea>
    </div>
    <button type="submit" class="btn-submit">Send Message</button>
  </form>
</section>
