    <div class="contact-form-col">
      <p class="section-label">Form</p>
      <h2 class="section-title" style="margin-bottom:2rem;">Tell us about<br>your <em>matter</em></h2>
      <p style="font-size:0.88rem; line-height:1.8; color:var(--charcoal-mid); margin-bottom:2.5rem;">Fill out the form to get in touch with us. All inquiries are reviewed directly by our partners.</p>

      <form name="contact-en" method="POST" action="/en/thank-you/" data-netlify="true" class="contact-form">
        <input type="hidden" name="form-name" value="contact-en">

        <div class="form-group">
          <label for="name">Full name *</label>
          <input type="text" id="name" name="name" required placeholder="Your name">
        </div>
        <div class="form-group">
          <label for="email">Email address *</label>
          <input type="email" id="email" name="email" required placeholder="you@company.com">
        </div>
        <div class="form-group">
          <label for="company">Company or organization</label>
          <input type="text" id="company" name="company" placeholder="Company name">
        </div>
        <div class="form-group">
          <label for="area">Area of interest</label>
          <select id="area" name="area">
            <option value="">Select an area</option>
            <option>Investment Consulting</option>
            <option>Litigation &amp; Alternative Dispute Resolution</option>
            <option>Corporate – M&amp;A</option>
            <option>Telecommunications</option>
            <option>Energy</option>
            <option>Due Diligence</option>
            <option>Pro Bono</option>
            <option>Other</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Message *</label>
          <textarea id="message" name="message" rows="5" required placeholder="Briefly describe your inquiry..."></textarea>
        </div>
        <button type="submit" class="btn-primary" style="width:100%; text-align:center;">Send Message</button>
      </form>
